#!/bin/sh

set -eu

expected_ruby_version="$(tr -d '\n' < .ruby-version)"
expected_ruby_version="${expected_ruby_version#ruby-}"

if [ "${1:-}" = "--docker" ]; then
  shift

  if ! docker compose version >/dev/null 2>&1; then
    echo "Docker Compose is required for Docker mode." >&2
    exit 1
  fi

  export DOCKER_UID="$(id -u)"
  export DOCKER_GID="$(id -g)"
  export RUBY_VERSION="$expected_ruby_version"

  exec docker compose run --build --rm site ruby scripts/update_passwords.rb "$@"
fi

if ! command -v ruby >/dev/null 2>&1; then
  echo "Local mode expects Ruby $expected_ruby_version. Use ./update-passwords --docker if you want the containerized path." >&2
  exit 1
fi

exec ruby scripts/update_passwords.rb "$@"
